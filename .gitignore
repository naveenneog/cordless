# deps
node_modules/

# build output (client is built into agent/public; rebuild with `npm run build`)
agent/public/
# self-contained CLI build output
agent/dist-sea/

# local runtime state / tests
.testhome/
*.log
agent/test/.restore-state.json

# playwright artifacts
.playwright-mcp/
*.png

# Sol working files (transcript + scratch answers are ephemeral; scripts + sol_plan.md are kept)
tooling/sol_conversation.json
tooling/answer_*.md
tooling/*.err

# capacitor / android build
android/app/build/
android/build/
android/.gradle/
android/local.properties
.DS_Store

# release artifacts / emulator captures
*.apk
emu-*.png

# keep docs images for the Pages landing page
!docs/*.png

# keep app icons/logos that the web build, Electron app and logo pipeline need
!client/public/*.png
!desktop/build/*.png
!tooling/logo/*.png

# private Sol/Azure endpoint config (never publish)
tooling/sol.local.json

# Android launcher/splash resources must be committed (cap sync does not regenerate them)
!android/**/*.png

# electron-builder output
desktop/release/
